# CARREGAR PACOTES
library(tidyverse)

# CRIAR OS DADOS
pacientes <- data.frame(
  nome_completo = c("João da Silva", "Maria Souza Santos", 
                    "Pedro Henrique Alves", "Ana Clara Oliveira"),
  data_do_atendimento = c("2024-07-12", "2024-07-12", "2024-07-12", "2024-07-11"),
  stringsAsFactors = FALSE
)

# SALVAR ARQUIVO ORIGINAL 
write.csv(pacientes, "pacientes.csv", row.names = FALSE, fileEncoding = "UTF-8")

# PROCESSAR COM PIPE ------------------------------------------------------
dados_processados <- read.csv("pacientes.csv", stringsAsFactors = FALSE) %>%
  mutate(
    # Extrair primeiro nome usando str_extract (regex)
    primeiro_nome = str_extract(nome_completo, "^[^ ]+"),
    
    # Extrair último nome usando str_extract (regex)
    ultimo_nome = str_extract(nome_completo, "[^ ]+$"),
    
  )

# SALVAR ARQUIVO PROCESSADO -----------------------------------------------
write.csv(dados_processados, "nomes_pacientes.csv", row.names = FALSE, fileEncoding = "UTF-8")

# VISUALIZAR RESULTADO ----------------------------------------------------
print(dados_processados)

