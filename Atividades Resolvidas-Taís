# EXERCÍCIO 1 : ANÁLISE DE NASCIMENTOS COM OPERADOR PIPE (%>%)

#  CARREGAR OS PACOTES N

library(tidyverse)      
library(microdatasus)   

# Declarando UMA ÚNICA variável para todo o processo
# Ano escolhido: 2022
# UF escolhida: São Paulo

resultado <- fetch_datasus(
  year_start = 2022,           
  year_end = 2022,
  uf = "SP",                   
  information_system = "SINASC"  
) %>%
  process_sinasc() %>%         
  mutate(
    # Extraindo o mês da data de nascimento
    mes_nascimento = month(DTNASC),
    # Criando nome do mês para melhor visualização
    nome_mes = factor(
      mes_nascimento,
      levels = 1:12,
      labels = c("Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho",
                 "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro")
    )
  ) %>%
  group_by(mes_nascimento, nome_mes) %>%  
  summarise(
    total_nascimentos = n(),              
    .groups = "drop"                      
  ) %>%
  arrange(mes_nascimento)                


# resultado
print(resultado)

